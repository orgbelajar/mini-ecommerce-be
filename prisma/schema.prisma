// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @db.VarChar(50)
  username String @unique @db.VarChar(50)
  password String @db.Text
  fullname String @db.VarChar(100)

  carts        Cart[]
  sharedCarts  CartSharedUser[]
  wishlist     Wishlist[]
  activities   CartActivity[]

  @@map("users")
}

model Authentication {
  token String @id @db.Text

  @@map("authentications")
}

model Category {
  id   String @id @db.VarChar(50)
  name String @db.VarChar(100)

  products Product[]

  @@map("categories")
}

model Product {
  id          String  @id @db.VarChar(50)
  name        String  @db.VarChar(150)
  description String? @db.Text
  price       Int
  stock       Int
  categoryId  String  @db.VarChar(50)

  category Category @relation(fields: [categoryId], references: [id])
  cartItems CartItem[]
  activities CartActivity[]
  wishlisted Wishlist[]

  @@map("products")
}

model Cart {
  id      String @id @db.VarChar(50)
  name    String @db.VarChar(100)
  ownerId String @db.VarChar(50)

  owner User @relation(fields: [ownerId], references: [id])

  items        CartItem[]
  collaborators CartSharedUser[]
  activities   CartActivity[]

  @@map("carts")
}

model CartItem {
  id        String @id @db.VarChar(50)
  cartId    String @db.VarChar(50)
  productId String @db.VarChar(50)
  qty       Int

  cart    Cart    @relation(fields: [cartId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model Wishlist {
  id        String @id @db.VarChar(50)
  userId    String @db.VarChar(50)
  productId String @db.VarChar(50)

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("wishlists")
}

model CartSharedUser {
  id     String @id @db.VarChar(50)
  cartId String @db.VarChar(50)
  userId String @db.VarChar(50)

  cart Cart @relation(fields: [cartId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("cart_shared_users")
}

model CartActivity {
  id        String   @id @db.VarChar(50)
  cartId    String   @db.VarChar(50)
  productId String   @db.VarChar(50)
  userId    String   @db.VarChar(50)
  action    String   @db.VarChar(50)
  time      DateTime @default(now())

  cart    Cart    @relation(fields: [cartId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("cart_activities")
}